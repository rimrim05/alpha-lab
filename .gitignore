/data/
# artifacts/ is ignored EXCEPT the live paper ledgers — they're the trading state the
# GitHub Actions paper run reads and commits back (git can't negate inside an ignored
# dir, hence the unignore chain)
/artifacts/*
!/artifacts/statarb/
/artifacts/statarb/*
!/artifacts/statarb/paper/
/artifacts/statarb/paper/*
!/artifacts/statarb/paper/live/
__pycache__/
*.egg-info/
.venv/
.venv-report/
.pytest_cache/
.env
.claude/
.DS_Store

# committed portfolio artifacts (NOT ignored): reports/, notebooks/, dashboard.html
research/hunt2026/*.parquet

# C++ extension build artifacts
*.so
build/

# Polygon reference cache (bulk external data, reproducible from the API)
research/stock_universe_repair/polygon_raw/
research/stock_universe_repair/sec_company_tickers.json

# superseded hunt2026 holdout snapshots, 55MB of them. The line above only matches the
# directory's direct children, so the archive slipped through and would have gone into
# history permanently. Same rule, one level down.
research/hunt2026/archive/

# Obsidian indexed this folder and left its editor config behind, same as .claude/
.obsidian/

/data/
# artifacts/ is ignored EXCEPT the live paper ledgers — they're the trading state the
# GitHub Actions paper run reads and commits back (git can't negate inside an ignored
# dir, hence the unignore chain)
/artifacts/*
!/artifacts/statarb/
/artifacts/statarb/*
!/artifacts/statarb/paper/
/artifacts/statarb/paper/*
!/artifacts/statarb/paper/live/
__pycache__/
*.egg-info/
.venv/
.venv-report/
.pytest_cache/
.env
.claude/
.DS_Store

# committed portfolio artifacts (NOT ignored): reports/, notebooks/, dashboard.html
